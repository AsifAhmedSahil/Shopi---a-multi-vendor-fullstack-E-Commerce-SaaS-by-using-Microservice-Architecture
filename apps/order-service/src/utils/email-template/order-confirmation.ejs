<!DOCTYPE html>
<html>
<head>
  <title>Your Order Confirmation</title>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    @media only screen and (max-width: 600px) {
      .email-container {
        width: 100% !important;
        padding: 15px !important;
      }
      .order-box {
        padding: 15px !important;
      }
    }
  </style>
</head>

<body style="margin:0; padding:0; background:#f7f7f7; font-family:Arial, sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td align="center" style="padding:20px;">
        
        <table class="email-container" width="600" cellpadding="0" cellspacing="0" style="background:#ffffff; border-radius:8px; padding:30px;">
          
          <!-- Logo -->
          <tr>
            <td align="center" style="padding-bottom:20px;">
              <img src="https://yourdomain.com/logo.png" width="140" alt="Shopi Logo" />
            </td>
          </tr>

          <!-- Greeting -->
          <tr>
            <td style="font-size:18px; color:#333;">
              <p>Hi <strong><%= name %></strong>,</p>
              <p>Thank you for shopping with <strong>Shopi</strong>! 🎉  
              Your order has been successfully confirmed.</p>
            </td>
          </tr>

          <!-- Order Info -->
          <tr>
            <td style="padding:20px 0;">
              <div style="background:#f2f2f2; padding:20px; border-radius:6px; font-size:16px; color:#333;">
                <strong>Order ID:</strong> <%= orderId %><br/>
                <strong>Status:</strong> Confirmed<br/>
                <strong>Order Date:</strong> <%= date %>
              </div>
            </td>
          </tr>

          <!-- Ordered Items -->
          <tr>
            <td>
              <h3 style="font-size:20px; color:#2c3e50; margin-bottom:10px;">Order Summary</h3>
              <table width="100%" cellpadding="0" cellspacing="0" style="border-collapse: collapse;">
                
                <%= itemsHtml %>
                <!-- 
                  Example of itemsHtml you send from backend:

                  <tr>
                    <td style="padding:10px 0; border-bottom:1px solid #eaeaea;">
                      <strong>Product Name</strong><br/>
                      Quantity: 2  •  Price: $20
                    </td>
                  </tr>
                -->

              </table>
            </td>
          </tr>

          <!-- Total -->
          <tr>
            <td align="right" style="padding:20px 0;">
              <h2 style="font-size:24px; color:#2c3e50;">
                Total: <span style="color:#27ae60;">$<%= total %></span>
              </h2>
            </td>
          </tr>

          <!-- Shipping Address -->
          <tr>
            <td style="padding-top:10px;">
              <h3 style="font-size:18px; color:#2c3e50;">Shipping Address</h3>
              <p style="font-size:16px; color:#555;">
                <%= address %>
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td align="center" style="padding-top:30px; font-size:12px; color:#aaaaaa;">
              &copy; <%= year %> Shopi. All rights reserved.<br/>
              <a href="https://yourdomain.com" style="color:#aaaaaa;">Visit our website</a>
            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>

</body>
</html>
